# ========== PostgreSQL to ByteHouse 同步配置 ==========

# ========== PostgreSQL 配置 ==========
PG_HOST=xxx.rds-pg.volces.com
PG_PORT=5432
PG_USER=root
PG_PASSWORD=xxx
PG_DATABASE=xxx

# ========== ByteHouse 配置 ==========
BH_HOST=xxx-cn-shanghai-public.bytehouse.volces.com
BH_PORT=19000
BH_USER=bytehouse
BH_PASSWORD=xxx
BH_DATABASE=xxx

# ========== 同步配置 ==========
SYNC_BATCH_SIZE=10000
INCREMENTAL_INTERVAL=60
# 要同步的表，支持逗号分隔、通配符
TABLE_PATTERN=user_transaction
# 增量同步时间字段
TIME_COLUMN=updated_at

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=./postgres_to_bytehouse.log

# ========== 告警配置 ==========
FEISHU_WEBHOOK=
